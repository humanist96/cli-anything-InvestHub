{
  "name": "invest-hub-mcp",
  "version": "1.0.0",
  "description": "MCP server for Korean/US stock analysis - quotes, technicals, AI scoring, backtesting",
  "type": "module",
  "bin": {
    "invest-hub-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "stock",
    "finance",
    "investment",
    "korea",
    "kospi",
    "nasdaq",
    "claude",
    "ai-analysis"
  ],
  "author": "humanist96",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "fast-xml-parser": "^5.0.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "openai": "^4.70.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
